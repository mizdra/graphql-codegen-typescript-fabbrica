{
  "name": "@mizdra/graphql-codegen-typescript-fabbrica",
  "version": "0.6.3",
  "private": false,
  "description": "GraphQL Code Generator Plugin to define mock data factory.",
  "keywords": [
    "graphql",
    "graphql-code-generator",
    "mock",
    "testing"
  ],
  "license": "MIT",
  "author": "mizdra <pp.mizdra@gmail.com>",
  "repository": "https://github.com/mizdra/graphql-codegen-typescript-fabbrica.git",
  "workspaces": [
    "e2e/01-esm",
    "e2e/02-browser"
  ],
  "files": [
    "src",
    "!src/test",
    "!src/**/*.test.ts",
    "!src/**/__snapshots__",
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "default": "./dist/esm/index.js"
    },
    "./helper": {
      "types": "./dist/esm/helper/index.d.ts",
      "default": "./dist/esm/helper/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "run-s -c build:*",
    "build:esm": "tsc -p tsconfig.build.json",
    "lint": "run-s -c lint:*",
    "lint:tsc": "tsc",
    "lint:oxlint": "oxlint",
    "lint:oxfmt": "oxfmt --check",
    "lint-fix": "run-s -c lint-fix:*",
    "lint-fix:oxlint": "oxlint --fix",
    "lint-fix:oxfmt": "oxfmt --write .",
    "test": "vitest",
    "e2e": "run-s -c setup-playwright build e2e:*",
    "e2e:esm": "npm -w e2e/01-esm run start",
    "e2e:browser": "npm -w e2e/02-browser run start",
    "e2e:portable": "npm --prefix e2e/03-portable run start",
    "setup-playwright": "npx playwright install --with-deps chromium"
  },
  "dependencies": {
    "@graphql-codegen/plugin-helpers": "^7.1.0",
    "@graphql-codegen/visitor-plugin-common": "^7.2.0",
    "graphql-relay": "^0.10.2"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^7.2.0",
    "@graphql-codegen/typescript": "^6.1.0",
    "@mizdra/oxfmt-config": "^0.2.0",
    "@mizdra/oxlint-config": "^0.5.0",
    "@types/node": "^26.1.1",
    "@vitest/browser-playwright": "^4.1.10",
    "graphql": "^16.9.0",
    "npm-run-all2": "^9.0.2",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "oxlint-tsgolint": "^0.24.0",
    "playwright": "^1.47.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "peerDependencies": {
    "graphql": "^16.0.0"
  },
  "devEngines": {
    "packageManager": {
      "name": "npm",
      "version": "12.0.0",
      "onFail": "warn"
    }
  },
  "engines": {
    "node": "^22.0.0 || ^24.0.0 || >=26.0.0"
  }
}
